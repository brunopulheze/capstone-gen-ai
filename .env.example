# ─────────────────────────────────────────────────────────
# BrixoAI Capstone — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to source control.
# ─────────────────────────────────────────────────────────

# ── LLM provider (required) ──────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Web search (required for UX Audit + Scope services) ──
# Get your key at: https://app.tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Embeddings (optional — improves RAG quality) ─────────
# Get your token at: https://huggingface.co/settings/tokens
# If not set, embeddings fall back to the public API (rate-limited)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LangSmith observability (optional but recommended) ────
# Get your key at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=brixoai-capstone
